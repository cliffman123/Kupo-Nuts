'); %7D %7D%3C/style%3E%3Cpath d='M 0,400 L 0,275 C 203.86666666666667,266.3333333333333 407.73333333333335,257.66666666666663 558,253 C 708.2666666666667,248.33333333333334 804.9333333333334,247.66666666666669 943,252 C 1081.0666666666666,256.3333333333333 1260.5333333333333,265.66666666666663 1440,275 L 1440,400 L 0,400 Z' stroke='none' stroke-width='0' fill='%232d2e2e' fill-opacity='1' class='transition-all duration-300 ease-in-out delay-150 path-2' transform='rotate(-180 720 200)'%3E%3C/path%3E%3C/svg%3E");
  background-size: auto 100%;
  background-repeat: repeat-x;
  background-position: 0 bottom;
  padding: 12px 20px;
  z-index: 1000;
  box-shadow: 0 2px 8px var(--shadow-medium);
  display: flex;
  justify-content: space-between;
  align-items: center;
}



/* Create sections for better layout control */
.left-section {
  display: flex;
  align-items: center;
  width: 33.3%;
}

.search-container {
  display: flex;
  align-items: center;
  width: 33.3%;
  max-width: 680px;
  position: relative;
  transition: all 0.3s ease;
}

/* Sort Dropdown Styles - matching collection dropdown */
.sort-dropdown-wrapper {
  display: flex;
  align-items: center;
  margin-left: 20px;
  position: relative;
}

.sort-dropdown-toggle {
  background-color: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 8px 14px;
  color: rgba(255, 255, 255, 0.9);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  border-radius: 8px;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
  min-width: 140px;
  justify-content: space-between;
}

.sort-dropdown-toggle:hover {
  background-color: rgba(255, 255, 255, 0.15);
  border-color: rgba(0, 191, 165, 0.3);
}

.sort-dropdown-toggle i.fa-chevron-down {
  transition: transform 0.2s ease;
  font-size: 12px;
}

.sort-dropdown-toggle i.fa-chevron-down.open {
  transform: rotate(180deg);
}

.sort-dropdown-menu {
  position: absolute;
  top: 100%;
  left: 0;
  background-color: rgba(30, 34, 40, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  margin-top: 6px;
  min-width: 200px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  z-index: 1000;
  backdrop-filter: blur(10px);
  animation: slideDown 0.2s ease;
}

.sort-dropdown-item {
  width: 100%;
  padding: 12px 16px;
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.7);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  text-align: left;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.sort-dropdown-item:first-child {
  border-radius: 7px 7px 0 0;
}

.sort-dropdown-item:last-child {
  border-radius: 0 0 7px 7px;
}

.sort-dropdown-item:hover {
  background-color: rgba(255, 255, 255, 0.1);
  color: #ffffff;
}

.sort-dropdown-item.active {
  background-color: rgba(0, 191, 165, 0.2);
  color: var(--primary-color);
  font-weight: 600;
}

.sort-dropdown-item i {
  font-size: 12px;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.sort-dropdown-item.active i {
  opacity: 1;
  color: var(--primary-color);
}

.right-section {
  display: flex;
  justify-content: flex-end;
  width: 33.3%;
}

/* Remove the hidden class effects */
.top-search-bar.hidden {
  /* Remove transform and opacity changes */
  transform: none;
  opacity: 1;
  display: none;
}

/* App title and logo styles */
.app-title {
  display: flex;
  align-items: center;
  color: var(--text-light);
  font-weight: bold;
  font-size: 1.2rem;
  margin-right: 5px; /* Reduced margin */
  white-space: nowrap;
}

.logo-icon {
  color: var(--primary-color);
  font-size: 24px;
  margin-right: 10px;
}

/* Enhanced search container */
.search-container {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 680px;
  position: relative;
  transition: all 0.3s ease;
}

/* Improved search input styling */
.search-input {
  flex-grow: 1;
  padding: 12px 60px 12px 16px;  /* Adjusted padding for consistency */
  font-size: 16px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  background-color: rgba(255, 255, 255, 0.08);
  color: var(--text-light);
  outline: none;
  transition: all 0.2s ease;
  box-shadow: none;
}

.search-input:focus {
  border-color: var(--primary-color);
  background-color: rgba(255, 255, 255, 0.12);
  box-shadow: 0 0 0 2px rgba(0, 191, 165, 0.15);
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
}

/* Profile button now in search bar */
.profile-button {
  position: static; /* Override the fixed position */
  margin-left: 0; /* Remove left margin */
  right: 40px; /* Position it to the right of the search bar */
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent;
  border: none;
  cursor: pointer;
  transition: background-color 0.3s, box-shadow 0.3s;
}

/* Update profile menu position */
.profile-menu {
  position: fixed; /* Change to fixed to ensure proper layering */
  top: 100px; /* Position below the top bar */
  right: 20px;
  background-color: var(--bg-card);
  min-width: 220px;
  padding: 8px 0;
  border-radius: var(--radius-medium);
  box-shadow: 0 8px 24px var(--shadow-heavy);
  border: 1px solid var(--border-color);
  z-index: 1050; /* Increase z-index to ensure it's above other elements */
  animation: menuSlide 0.25s ease-out;
  max-height: calc(100vh - 80px); /* Prevent overflow */
  overflow-y: auto;
  overflow-x: hidden;
  transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
}

.profile-menu-header {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border-color);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.profile-menu-header h3 {
  margin: 0;
  font-size: 16px;
  color: var(--text-light);
  font-weight: 500;
}

.profile-menu-header button {
  background: none;
  border: none;
  color: var(--text-light);
  cursor: pointer;
  padding: 4px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-menu-header button:hover {
  background-color: rgba(255, 255, 255, 0.1);
}

/* Ensure menu buttons are more distinct */
.profile-menu-button {
  width: 100%;
  text-align: left;
  background: none;
  border: none;
  padding: 12px 16px;
  color: var(--text-light);
  font-size: 14px;
  cursor: pointer;
  display: flex;
  align-items: center;
  transition: background-color 0.2s ease;
}

.profile-menu-button:hover {
  background-color: rgba(255, 255, 255, 0.1);
}

.profile-menu-button i {
  margin-right: 12px;
  width: 20px;
  text-align: center;
  font-size: 16px;
}

.profile-menu-divider {
  height: 1px;
  background-color: var(--border-color);
  margin: 8px 0;
}

.profile-menu-button.danger {
  color: var(--danger-color);
}

.profile-menu-button.danger:hover {
  background-color: rgba(255, 82, 82, 0.15);
}

/* Make profile button more visible */
.profile-button {
  position: relative; /* Change to relative for better positioning context */
  z-index: 1049; /* Just below the menu */
}

.profile-button:hover {
  background-color: var(--primary-hover);
}

.profile-button.logged-in {
  background-color: #fff;
  border: 2px solid var(--primary-color);
}

/* Adjust content filter toggle styling for the settings panel */
.content-filter-toggle.settings-toggle {
  width: 100%;
  margin-left: 0;
  border-radius: var(--radius-medium);
}

.settings-toggle .content-filter-option {
  flex: 1; /* Make buttons take equal width */
  text-align: center;
  font-size: 16px;
  padding: 12px;
}

/* Consolidated Content Filter Styling */
.content-filter-toggle.settings-toggle {
  width: 100%;
  display: flex;
  background-color: rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-large);
  padding: 4px;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.05);
  margin-bottom: 5px;
}

.settings-toggle .content-filter-option {
  flex: 1;
  text-align: center;
  font-size: 15px;
  padding: 12px 0;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.7);
  background: transparent;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
  border-radius: var(--radius-medium);
}

.settings-toggle .content-filter-option.active {
  color: var(--text-dark);
  font-weight: 600;
  transform: translateY(-1px);
}

.settings-toggle .content-filter-option:first-child {
  margin-right: 4px;
}

.settings-toggle .content-filter-option:first-child.active {
  background-color: #4caf50;
  box-shadow: 0 2px 6px rgba(76, 175, 80, 0.4);
}

.settings-toggle .content-filter-option:last-child.active {
  background-color: var(--danger-color);
  box-shadow: 0 2px 6px rgba(255, 82, 82, 0.4);
}

.settings-toggle .content-filter-option:hover:not(.active) {
  background-color: rgba(255, 255, 255, 0.1);
  color: var(--text-light);
}

/* Active filter indicator */
.active-filter-indicator {
  position: fixed;
  top: 70px; /* Keep consistent with search bar visible */
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(0, 191, 165, 0.9);
  color: var(--text-dark);
  padding: 8px 15px;
  border-radius: 0 0 15px 15px;
  z-index: 1000;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 2px 8px var(--shadow-medium);
}

/* Hide the global filter indicator when in fullscreen mode */
.media-wrapper.fullscreen ~ .active-filter-indicator,
body:has(.media-wrapper.fullscreen) .active-filter-indicator {
  display: flex;
}

/* Notifications */
.notifications-container {
  position: fixed;
  left: 20px;
  top: 70px;
  z-index: 1010;
  pointer-events: none;
}

.notification {
  position: absolute;
  left: 0;
  padding: 15px 20px;
  border-radius: var(--radius-small);
  min-width: 250px;
  max-width: 350px;
  background-color: #2e2e2e;
  box-shadow: 0 4px 6px var(--shadow-medium);
  animation: slideInLeft 0.3s ease-out;
  pointer-events: auto;
  transition: top 0.3s ease-in-out;
}

.notification.success {
  background-color: #1a2e2b;
  border-left: 4px solid var(--primary-color);
}

.notification.error {
  background-color: #2e1a1a;
  border-left: 4px solid var(--danger-color);
}

.notification.info {
  background-color: #1a202e;
  border-left: 4px solid #2196f3;
}

.notification.progress {
  background-color: #1a2e2b;
  border-left: 4px solid var(--primary-color);
}

.notification-message {
  margin: 0;
  font-size: 14px;
}

.notification-completed {
  text-align: center;
  color: var(--primary-color);
  font-weight: 500;
}

.notification-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  height: 3px;
  background-color: rgba(255, 255, 255, 0.3);
  animation: progress 3s linear;
}

/* Circular Progress Indicator - Inline with message */
.notification-progress-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
}

.notification-progress-circle {
    position: relative;
    width: 50px;
    height: 50px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
}

.progress-ring {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
}

.progress-ring-bg {
    fill: none;
    stroke: rgba(0, 191, 165, 0.2);
    stroke-width: 3;
}

.progress-ring-fill {
    fill: none;
    stroke: var(--primary-color);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 282.7;
    stroke-dashoffset: 282.7;
    transition: stroke-dashoffset 0.3s ease;
}

.notification-progress-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    font-size: 11px;
    font-weight: bold;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
    z-index: 1;
}

.notification-count {
  margin-top: 8px;
  font-size: 12px;
  color: #888;
  text-align: center;
}

.notification-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8px;
}

.notification-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(0, 191, 165, 0.3);
  border-radius: 50%;
  border-top-color: var(--primary-color);
  animation: spin 1s linear infinite;
}

/* Tags panel styles */
.tags-panel {
  position: fixed;
  left: 0;
  top: 0;
  width: 200px;
  height: 95vh;
  background-color: rgba(30, 30, 30, 0.9);
  color: var(--text-light);
  padding: 20px;
  overflow-y: auto;
  z-index: 1002;
  box-shadow: 2px 0 10px var(--shadow-medium);
  display: none;
  scrollbar-width: thin;
}

.media-wrapper.fullscreen .tags-panel {
  display: block;
}

.tags-header {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 15px;
  border-bottom: 1px solid #444;
  padding-bottom: 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tags-header .clear-button {
  background-color: rgba(255, 255, 255, 0.1);
  border: none;
  border-radius: 50%;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--text-light);
  transition: background-color 0.2s;
}

.tags-header .clear-button:hover {
  background-color: rgba(255, 82, 82, 0.3);
}

.tags-header .minimize-button:hover {
  background-color: rgba(0, 191, 165, 0.1);
  border-color: var(--primary-color);
  transform: scale(1.05);
}

.tags-header .minimize-button:active {
  transform: scale(0.95);
}

.tag-category {
  margin-bottom: 10px;
}

.tag-category-header {
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 5px;
  color: #ddd;
  padding-left: 4px;
  border-left: 3px solid #4a90e2;
}

.tags-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.tag-container {
  position: relative;
  display: flex;
  align-items: center;
  margin: 2px;
  width: 100%;
}

.tag {
  padding: 4px 8px;
  border-radius: 4px;
  background-color: #2a2a2a;
  color: #ffffff;
  font-size: 15px;
  font-weight: 500;
  letter-spacing: 0.3px;
  cursor: pointer;
  margin-right: 4px;
  transition: background-color 0.2s;
  border: 1px solid #3a3a3a;
  display: inline-block;
}

.tag:hover {
  background-color: #3a3a3a;
}

.tag.active {
  background-color: #4a90e2;
  border-color: #3a80d2;
}

.tag-actions {
  display: flex;
  position: static;
  right: auto;
  top: auto;
  transform: none;
  z-index: 10;
  gap: 4px;
  border: none;
}

.tag-action {
  width: auto;
  height: auto;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  cursor: pointer;
  font-size: 16px;
  opacity: 1;
  transition: all 0.2s;
  background: none;
  padding: 0 6px;
  margin: 0;
}

.tag-container:hover .tag-actions {
  display: flex;
}

.tag-action:hover {
  opacity: 1;
  transform: scale(1.1);
}

.tag-action-plus {
  background-color: transparent;
  color: #2ecc71;
}

.tag-action-minus {
  background-color: transparent;
  color: #e74c3c;
}

.tag-author {
  background-color: #9b59b6;
  border-color: #8e44ad;
}

.tag-copyright {
  background-color: #3498db;
  border-color: #2980b9;
}

.tag-character {
  background-color: #e67e22;
  border-color: #d35400;
}

.tag-general {
  background-color: #2a2a2a;
  border-color: #3a3a3a;
}

/* Ensure tags panel is visible in fullscreen mode */
.fullscreen .tags-panel {
  display: block;
  position: absolute;
  top: 10px;
  right: 10px;
  background-color: rgba(25, 25, 25, 0.9);
  border-radius: 8px;
  padding: 10px;
  max-width: 150px;
  max-height: 80vh;
  overflow-y: auto;
  z-index: 1001;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
}

.tag.active:hover {
  background-color: #f0f0f0;
}

.clear-tag-filter:hover {
  background-color: var(--danger-color);
}

/* Loading states */
.loading-placeholder {
  width: 100%;
  padding-top: 56.25%;
  background-color: #f0f0f0;
}

.media-loaded {
  animation: fadeIn 0.5s ease-in;
}

.media-loading {
  background-color: #242424;
  min-height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-loading::after {
  content: "";
  width: 40px;
  height: 40px;
  border: 4px solid rgba(255, 255, 255, 0.1);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* Image loading placeholder - gray background with spinner */
.image-loading-placeholder {
  width: 100%;
  height: 100%;
  min-height: 300px;
  background-color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-medium);
  animation: fadeIn 0.3s ease-in;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(255, 255, 255, 0.2);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background: #1e1e1e;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb {
  background: #333;
  border-radius: 10px;
  border: 2px solid #1e1e1e;
  transition: all 0.3s ease;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--primary-color);
}

::-webkit-scrollbar-corner {
  background: #1e1e1e;
}

.tags-panel::-webkit-scrollbar {
  width: 6px;
}

.tags-panel::-webkit-scrollbar-thumb {
  background: #444;
}

.tags-panel::-webkit-scrollbar-thumb:hover {
  background: var(--primary-color);
}

/* Improve scroll speed slider styling */
.scroll-speed-slider {
  width: 100%;
  height: 6px;
  -webkit-appearance: none;
  appearance: none;
  background: #333;
  background-image: linear-gradient(to right, var(--primary-color), var(--primary-color));
  background-size: 30% 100%;
  background-repeat: no-repeat;
  outline: none;
  border-radius: 10px;
  margin: 15px 0;
  cursor: pointer;
}

.scroll-speed-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--primary-color);
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 2px 5px var(--shadow-medium);
  border: 2px solid rgba(255, 255, 255, 0.8);
}

.scroll-speed-slider::-webkit-slider-thumb:hover,
.scroll-speed-slider:active::-webkit-slider-thumb {
  transform: scale(1.15);
  box-shadow: 0 3px 8px var(--shadow-medium);
}

.speed-range-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 10px;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
}

/* Volume slider styles */
.volume-slider {
  width: 100%;
  height: 6px;
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
  background: #333;
  background-image: linear-gradient(to right, var(--primary-color), var(--primary-color));
  background-size: 10% 100%; /* Default to 10% */
  background-repeat: no-repeat;
  outline: none;
  border-radius: 10px;
  margin: 15px 0;
  cursor: pointer;
}

.volume-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  -moz-appearance: none;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--primary-color);
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 2px 5px var(--shadow-medium);
  border: 2px solid rgba(255, 255, 255, 0.8);
}

.volume-slider::-webkit-slider-thumb:hover,
.volume-slider:active::-webkit-slider-thumb {
  transform: scale(1.15);
  box-shadow: 0 3px 8px var(--shadow-medium);
}

.volume-range-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 10px;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
}

/* Content filter button for top search bar */
.content-filter-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 52px;
  height: 36px;
  border-radius: 18px;
  border: none;
  margin-right: 2px; /* Reduced margin */
  margin-left: 10px; /* Added margin-left for spacing from app title */
  cursor: pointer;
  transition: all 0.2s ease;
  color: var(--text-light);
  outline: none;
  box-shadow: 0 2px 4px var(--shadow-light);
  font-weight: bold;
  padding: 0 12px;
  font-size: 14px;
}

.content-filter-button.sfw {
  background-color: #4caf50;
}

.content-filter-button.nsfw {
  background-color: #f44336;
}

.content-filter-button:hover {
  transform: scale(1.05);
  box-shadow: 0 3px 6px var(--shadow-medium);
}

.content-filter-button:active {
  transform: scale(0.97);
}

/* Blacklist controls */
.blacklist-controls {
  display: flex;
  width: 100%;
  gap: 8px;
  align-items: center;
}

.blacklist-controls input {
  flex: 1;
}

.delete-blacklisted-button {
  padding: 14px 16px;
  background-color: var(--danger-color);
  border: none;
  border-radius: 12px;
  color: white;
  cursor: pointer;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.delete-blacklisted-button:hover {
  background-color: var(--danger-hover);
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
  transform: translateY(-1px);
}

.delete-blacklisted-button i {
  font-size: 14px;
}

/* Animations */
@keyframes slideInLeft {
  from { transform: translateX(-100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@keyframes progress {
  from { width: 100%; }
  to { width: 0%; }
}

@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.97); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes menuSlide {
  from { opacity: 0; transform: translateY(-10px) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Utility classes */
.mt-16 {
  margin-top: 16px;
}

/* For Firefox */
* {
  scrollbar-width: thin;
  scrollbar-color: #333 #1e1e1e;
}

/* Responsive improvements */
@media screen and (max-width: 768px) {
  /* Top navigation bar */
  .top-search-bar {
    flex-direction: column;
    padding: 8px 5px;
    gap: 8px;
  }

  .app-title {
    font-size: 1.2rem;
    margin-bottom: 5px;
  }

  .left-section, .right-section {
    width: 100%;
    justify-content: center;
  }

  .search-container {
    width: 100%;
    max-width: none;
  }

  .search-input {
    font-size: 14px;
    padding: 8px 12px;
  }
  
  .content-filter-button {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 12px;
    padding: 5px 8px;
  }

  /* Notifications */
  .notifications-container {
    width: 90%;
    left: 5%;
  }

  .notification {
    padding: 8px;
    font-size: 14px;
  }

  /* Profile menu */
  .profile-button {
    position: absolute;
    top: 8px;
    right: 70px;
  }

  .profile-menu {
    width: 90%;
    left: 5%;
    right: 5%;
  }

  .media-wrapper {
    margin-bottom: 10px;
  }
  
  .media-container {
    max-height: 80vh;
  }

  /* Settings dialog */
  .settings-dialog {
    padding: 0;
  }

  .settings-content {
    width: 90%;
    max-width: 90%;
    max-height: 80vh;
    padding: 10px;
  }

  .settings-header h2 {
    font-size: 1.2rem;
  }

  .settings-item {
    flex-direction: column;
    align-items: flex-start;
  }

  .settings-item label {
    margin-bottom: 5px;
    width: 100%;
  }

  /* Login dialog */
  .login-dialog {
    padding: 0;
  }

  .login-content {
    width: 90%;
    max-width: 90%;
    padding: 15px;
  }

  .login-header h2 {
    font-size: 1.2rem;
  }

  /* Active filter indicator */
  .active-filter-indicator {
    font-size: 14px;
    padding: 10px;
    top: 110px;
  }

  /* Collection tabs styling */
  .collection-tabs {
    width: 100%;
    justify-content: center;
    margin-left: 0;
    margin-top: 10px;
    margin-bottom: 10px;
  }

  .collection-tab {
    padding: 6px 12px;
    font-size: 13px;
  }
}

/* Very small screens (mobile phones in portrait) */
@media screen and (max-width: 480px) {
  .top-search-bar {
    padding-top: 40px; /* Make room for the profile and content filter buttons */
  }

  /* Overlay notifications positioning */
  .notifications-container {
    width: 95%;
    left: 2.5%;
  }
  
  /* Make sure the filter indicator doesn't overlap with content */
  .active-filter-indicator {
    top: 150px;
  }

  .collection-tab {
    padding: 5px 8px;
    font-size: 12px;
    margin-right: 4px;
  }
}

/* Additional fixes for landscape mode on mobile */
@media screen and (max-height: 500px) and (orientation: landscape) {
  .fullscreen .media-container {
    max-height: 70vh;
  }

  .tags-panel {
    max-height: 30vh;
  }
  
  .settings-content, .login-content {
    max-height: 90vh;
  }
}

/* Improve scrolling experience on mobile */
.tags-panel,
.settings-content,
.profile-menu-content {
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;
}

/* Collection tabs styling */
.collection-tabs {
  display: flex;
  margin-left: 20px;
  align-items: center;
}

.collection-tab {
  background: none;
  border: none;
  padding: 8px 16px;
  color: rgba(255, 255, 255, 0.7);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  border-radius: 18px;
  transition: all 0.2s ease;
  margin-right: 8px;
  position: relative;
  overflow: hidden;
}

.collection-tab:hover {
  background-color: rgba(255, 255, 255, 0.1);
  color: #ffffff;
}

.collection-tab.active {
  background-color: var(--primary-color);
  color: var(--text-dark);
  font-weight: 600;
  box-shadow: 0 2px 6px rgba(0, 191, 165, 0.4);
}

.collection-tab.active:hover {
  background-color: var(--primary-hover);
}

.fullscreen-active .tags-panel {
    display: block !important;
}

/* Tags panel minimized state - Minimalist Sliding Door */
.tags-panel.minimized {
  width: 40px;
  padding: 0;
  padding-top: 0;
  min-width: auto;
  max-width: none;
  height: 100%;
  max-height: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 20px;
  overflow: hidden;
  background: transparent;
  border-right: none;
  box-shadow: none;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.tags-panel.minimized .tags-header {
  font-size: 0;
  font-weight: bold;
  margin-bottom: 0;
  margin-top: 20px;
  border-bottom: none;
  padding-bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  height: auto;
}

.tags-panel.minimized .tags-header-controls {
  width: 100%;
  display: flex;
  justify-content: center;
}

.tags-panel.minimized .tags-minimize-button {
  width: 36px;
  height: 36px;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  color: var(--primary-color);
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  font-size: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}

.tags-panel.minimized .tags-minimize-button:hover {
  background: transparent;
  box-shadow: none;
  transform: translateX(4px);
  color: var(--primary-hover);
}

.tags-panel.minimized .tags-minimize-button:active {
  transform: scale(0.95);
}

/* Hide everything else when minimized */
.tags-panel.minimized .tags-content,
.tags-panel.minimized .tag-filter-info,
.tags-panel.minimized .tag-category {
  display: none;
}

/* Non-minimized header button styling */
.tags-header .tags-minimize-button {
  width: auto;
  padding: 6px 8px;
  background: transparent;
  border: none;
  border-radius: 4px;
  color: var(--primary-color);
  cursor: pointer;
  transition: all 0.2s ease;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8px;
}

.tags-header .tags-minimize-button:hover {
  background-color: rgba(0, 191, 165, 0.1);
  border-radius: 50%;
  border-color: var(--primary-color);
  transform: scale(1.05);
}

.tags-header .tags-minimize-button:active {
  transform: scale(0.95);
}

/* Confirm Dialog Styles */
.confirm-dialog {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.75);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1007;
  backdrop-filter: blur(10px);
  animation: fadeIn 0.3s ease;
  overflow: hidden;
}

.confirm-content {
  background: linear-gradient(135deg, #1e2329 0%, #252a33 100%);
  padding: 30px;
  border-radius: 18px;
  width: 90%;
  max-width: 460px;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), 
              0 5px 20px rgba(0, 0, 0, 0.4),
              inset 0 1px 1px rgba(255, 255, 255, 0.07);
  transform: translateY(0);
  animation: slideUp 0.4s cubic-bezier(0.19, 1, 0.22, 1);
  border: 1px solid rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

.confirm-content::before {
  content: "";
  position: absolute;
  top: -50px;
  right: -50px;
  width: 180px;
  height: 180px;
  background: radial-gradient(circle, rgba(255, 82, 82, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.confirm-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28px;
  padding-bottom: 18px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  position: relative;
}

.confirm-header::after {
  content: "";
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 80px;
  height: 3px;
  background: linear-gradient(90deg, var(--danger-color), rgba(255, 82, 82, 0.2));
  border-radius: 3px;
}

.confirm-header h2 {
  margin: 0;
  color: var(--text-light);
  font-size: 1.6rem;
  font-weight: 500;
  letter-spacing: 0.5px;
  background: linear-gradient(to right, #ff8686, #ffffff);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.confirm-body {
  margin: 20px 0;
  color: var(--text-light);
  font-size: 1rem;
  line-height: 1.6;
}

.confirm-body p {
  margin: 10px 0;
}

.confirm-body strong {
  color: var(--danger-color);
}

.confirm-options {
  display: flex;
  gap: 12px;
  margin-top: 30px;
  justify-content: flex-end;
}

.confirm-options button {
  padding: 10px 20px;
  border: none;
  border-radius: 6px;
  font-size: 1rem;
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.confirm-options button:first-child {
  background-color: rgba(255, 255, 255, 0.1);
  color: var(--text-light);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.confirm-options button:first-child:hover {
  background-color: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.3);
}

.confirm-options button:last-child {
  background-color: var(--danger-color);
  color: var(--text-dark);
}

.confirm-options button:last-child:hover {
  background-color: var(--danger-hover);
  box-shadow: 0 0 20px rgba(255, 82, 82, 0.3);
}

.confirm-options button:active {
  transform: scale(0.98);
}

.media-masonry {
  display: flex;
  width: auto;
  margin-left: 0;
  transition: height 0.3s ease;
}

.media-masonry-column {
  padding-left: 4px; /* Space between columns */
  background-clip: padding-box;
}

/* First column gets no left padding */
.media-masonry-column:first-child {
  padding-left: 0;
}

.media-masonry-column > .media-wrapper {
  margin-bottom: 16px;
  display: block;
  width: 100%;
}

.media-masonry-column > .media-wrapper:last-child {
  margin-bottom: 0;
}

/* Responsive column layout for React Masonry */
@media (min-width: 1600px) {
  .media-masonry {
    column-count: 4;
  }
}

@media (min-width: 1200px) and (max-width: 1599px) {
  .media-masonry {
    column-count: 4;
  }
}

@media (min-width: 900px) and (max-width: 1199px) {
  .media-masonry {
    column-count: 3;
  }
}

@media (min-width: 600px) and (max-width: 899px) {
  .media-masonry {
    column-count: 2;
  }
}

@media (max-width: 599px) {
  .media-masonry {
    column-count: 1;
  }
}

.fullscreen-active .tags-panel {
    display: block !important;
}

.image-loading-placeholder {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
}

.retry-indicator {
    font-size: 12px;
    color: #999;
    font-weight: 500;
    margin-top: 8px;
}

.notification-close-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    font-size: 16px;
    padding: 4px 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.7;
    transition: opacity 0.2s ease;
}

.notification-close-btn:hover {
    opacity: 1;
}

/* Search buttons group - inside input */
.search-buttons-group {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    gap: 4px;
    align-items: center;
    z-index: 2;
}

/* Auto scrape button inside search input */
.auto-scrape-button-top {
    background-color: transparent;
    border: none;
    color: var(--danger-color);
    padding: 6px 8px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
}

.auto-scrape-button-top:hover {
    transform: scale(1.1);
}

.auto-scrape-button-top.active {
    color: var(--primary-color);
}

.auto-scrape-button-top i {
    font-size: 20px;
}

/* Search button inside input */
.search-button {
    background-color: transparent;
    color: var(--text-light);
    border: none;
    padding: 6px 8px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.search-button:hover {
    color: var(--primary-color);
    transform: scale(1.05);
}

.search-button i {
    font-size: 20px;
}

/* Collection Tabs / Dropdown Styles */
.collection-tabs-wrapper {
  display: flex;
  align-items: center;
  margin-right: 80px;
  position: relative;
}

/* Desktop tabs view */
.collection-tabs.collection-tabs-desktop {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.collection-tabs.collection-tabs-desktop .collection-tab {
  background: none;
  border: none;
  padding: 8px 16px;
  color: rgba(255, 255, 255, 0.7);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  border-radius: 18px;
  transition: all 0.2s ease;
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}

.collection-tabs.collection-tabs-desktop .collection-tab:hover {
  background-color: rgba(255, 255, 255, 0.1);
  color: #ffffff;
}

.collection-tabs.collection-tabs-desktop .collection-tab.active {
  background-color: var(--primary-color);
  color: var(--text-dark);
  font-weight: 600;
  box-shadow: 0 2px 6px rgba(0, 191, 165, 0.4);
}

.collection-tabs.collection-tabs-desktop .collection-tab.active:hover {
  background-color: var(--primary-hover);
}

/* Mobile dropdown view */
.collection-dropdown-wrapper {
  display: none;
  position: relative;
}

.collection-dropdown-toggle {
  background-color: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 8px 14px;
  color: rgba(255, 255, 255, 0.9);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  border-radius: 8px;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
  min-width: 140px;
  justify-content: space-between;
}

.collection-dropdown-toggle:hover {
  background-color: rgba(255, 255, 255, 0.15);
  border-color: rgba(0, 191, 165, 0.3);
}

.collection-dropdown-toggle i.fa-chevron-down {
  transition: transform 0.2s ease;
  font-size: 12px;
}

.collection-dropdown-toggle i.fa-chevron-down.open {
  transform: rotate(180deg);
}

.collection-dropdown-menu {
  position: absolute;
  top: 100%;
  left: 0;
  background-color: rgba(30, 34, 40, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  margin-top: 6px;
  min-width: 200px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  z-index: 1000;
  backdrop-filter: blur(10px);
  animation: slideDown 0.2s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.collection-dropdown-item {
  width: 100%;
  padding: 12px 16px;
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.7);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  text-align: left;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.collection-dropdown-item:first-child {
  border-radius: 7px 7px 0 0;
}

.collection-dropdown-item:last-child {
  border-radius: 0 0 7px 7px;
}

.collection-dropdown-item:hover {
  background-color: rgba(255, 255, 255, 0.1);
  color: #ffffff;
}

.collection-dropdown-item.active {
  background-color: rgba(0, 191, 165, 0.2);
  color: var(--primary-color);
  font-weight: 600;
}

.collection-dropdown-item i {
  font-size: 12px;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.collection-dropdown-item.active i {
  opacity: 1;
  color: var(--primary-color);
}

/* Responsive: Show dropdown on smaller screens */
@media screen and (max-width: 1920px) {
  .collection-tabs-wrapper {
    margin-left: 10px;
  }

  .collection-tabs.collection-tabs-desktop {
    display: none;
  }

  .collection-dropdown-wrapper {
    display: block;
  }
}
